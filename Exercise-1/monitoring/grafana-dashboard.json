{
  "title": "Payment Service Health",
  "uid": "payment-service-health",
  "tags": ["payment", "slo"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "rate(payment_service_requests_total[5m])",
          "legendFormat": "{{method}} {{endpoint}} {{status}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error Rate (%)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "rate(payment_service_errors_total[5m]) / rate(payment_service_requests_total[5m]) * 100",
          "legendFormat": "{{endpoint}} error %"
        }
      ]
    },
    {
      "id": 3,
      "title": "P95 Latency (ms)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(payment_service_request_latency_seconds_bucket[5m])) * 1000",
          "legendFormat": "p95 {{endpoint}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Total Requests",
      "type": "stat",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(payment_service_requests_total)",
          "legendFormat": "Total"
        }
      ]
    },
    {
      "id": 5,
      "title": "Total Errors",
      "type": "stat",
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(payment_service_errors_total)",
          "legendFormat": "Errors"
        }
      ]
    }
  ]
}
